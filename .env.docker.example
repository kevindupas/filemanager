APP_NAME=FileManager
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_TIMEZONE=UTC
# Public URL — Use https://... behind a reverse proxy.
APP_URL=http://your-server-host:8080
APP_PORT=8080

APP_LOCALE=en
APP_FALLBACK_LOCALE=en

# Docker logs → container stdout/stderr.
LOG_CHANNEL=stderr
LOG_LEVEL=warning

# Postgres service (internal docker network).
DB_CONNECTION=pgsql
DB_HOST=db
DB_PORT=5432
DB_DATABASE=filemanager
DB_USERNAME=filemanager
DB_PASSWORD=change-this-strong-password

# Sessions in the DB, cache + queue on Redis (background transfers need the worker).
SESSION_DRIVER=database
SESSION_LIFETIME=120
QUEUE_CONNECTION=redis
CACHE_STORE=redis
CACHE_PREFIX=

REDIS_CLIENT=phpredis
REDIS_HOST=redis
REDIS_PASSWORD=null
REDIS_PORT=6379

FILESYSTEM_DISK=local
BROADCAST_CONNECTION=log

MAIL_MAILER=log
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

VITE_APP_NAME="${APP_NAME}"
